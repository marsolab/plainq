---
import Logo from "./Logo.astro";

const columns = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "/#features" },
      { label: "Usage", href: "/#usage" },
      { label: "Deploy", href: "/#deploy" },
    ],
  },
  {
    title: "Docs",
    links: [
      { label: "Quickstart", href: "/docs/getting-started/quickstart/" },
      { label: "Installation", href: "/docs/getting-started/installation/" },
      { label: "Core concepts", href: "/docs/getting-started/core-concepts/" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "GitHub", href: "https://github.com/marsolab/plainq" },
      { label: "Issues", href: "https://github.com/marsolab/plainq/issues" },
      {
        label: "Discussions",
        href: "https://github.com/marsolab/plainq/discussions",
      },
    ],
  },
];
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-background)]">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center" aria-label="PlainQ home">
          <Logo />
        </a>
        <p class="mt-4 max-w-xs text-sm text-[var(--color-muted-foreground)]">
          Truly Simple Queue Service. One binary, no broker fleet. ☺️
        </p>
      </div>

      {
        columns.map((column) => (
          <div>
            <h3 class="text-sm font-semibold">{column.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)]"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-[var(--color-border)] pt-6 text-sm text-[var(--color-muted-foreground)] sm:flex-row"
    >
      <p>© {year} PlainQ · Apache License 2.0</p>
      <p class="font-mono text-xs">Built with Astro · Tailwind · React</p>
    </div>
  </div>
</footer>
