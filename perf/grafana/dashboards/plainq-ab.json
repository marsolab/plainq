        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["plainq", "performance", "ab"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_VM",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "PlainQ AB Performance",
  "uid": "plainq-ab-perf",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "End-to-end latency (op=total)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "p95 latency (total)",
      "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
          "expr": "avg by (variant) (k6_plainq_latency_p95{op=\"total\"})",
          "legendFormat": "{{variant}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p99 latency (total)",
      "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
          "expr": "avg by (variant) (k6_plainq_latency_p99{op=\"total\"})",
          "legendFormat": "{{variant}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Iterations / sec (total)",
      "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
          "expr": "sum by (variant) (rate(k6_plainq_reqs_total{op=\"total\"}[$__rate_interval]))",
          "legendFormat": "{{variant}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
          "expr": "sum by (variant) (rate(k6_plainq_errs_total{op=\"total\"}[$__rate_interval])) / clamp_min(sum by (variant) (rate(k6_plainq_reqs_total{op=\"total\"}[$__rate_interval])), 1)",
          "legendFormat": "{{variant}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency over time (total)",
      "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VM}" },
          "expr": "avg by (variant) (k6_plainq_latency_p95{op=\"total\"})",
          "legendFormat": "{{variant}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
