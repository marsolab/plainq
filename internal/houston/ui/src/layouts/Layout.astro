---
import { Toaster } from "@/components/ui/toaster";

interface Props {
  title?: string;
}

const { title = "PlainQ Houston" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="PlainQ Houston — queue and topic operations" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Toaster client:idle />
  </body>
</html>

<style is:global>
  @import "../styles/globals.css";
</style>
